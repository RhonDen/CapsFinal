# === AppointEase / CAPSPROJ ===
# Production-ready environment variables.
# IMPORTANT: Put your real values here.

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (MongoDB Atlas)
# Example format (paste your real password):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=AppName
MONGODB_URI=

# Database (optional) - choose MySQL or SQLite.
# To use MySQL, set DB_DIALECT=mysql and provide credentials.
# To use local SQLite for development, set DB_DIALECT=sqlite or leave credentials blank.
# Example MySQL:
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=secret
# DB_NAME=appointease
# Example SQLite:
# DB_DIALECT=sqlite
DB_DIALECT=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=appointease
SQLITE_STORAGE=database.sqlite

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1h

# Default admin (used only in local development if you changed NODE_ENV to development)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# SMS provider (UniSender)
# If you don’t want OTP for now, you can set these to dummy values, but sendSMS will fail.
UNI_SMS_API_KEY=
UNI_SMS_SENDER_ID=AppointEase

